NODE_ENV=production

# Supabase credentials used by the RSS engine worker.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Worker cadence (default 10 minutes).
RSS_INGESTION_INTERVAL_MS=600000

# RSS fetch runtime controls.
RSS_CONCURRENCY=5
RSS_FETCH_TIMEOUT_MS=10000
RSS_FETCH_RETRY_ATTEMPTS=3
RSS_FETCH_RETRY_BASE_DELAY_MS=500
INSERT_BATCH_SIZE=50
