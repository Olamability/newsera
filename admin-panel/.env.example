# Supabase project URL (from Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (from Supabase dashboard → Project Settings → API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Base URL of the @newsera/moderation-service (admin moderation API).
# Leave empty in environments where the service isn't running — read-only
# moderation views will still work, but action buttons will surface an
# informative error instead of silently doing nothing.
VITE_MODERATION_API_URL=

# VITE_ADMIN_EMAIL is no longer used for access control.
# Admin access is now granted via Supabase app_metadata.role = "admin".
# To promote a user to admin, run the following SQL in your Supabase SQL Editor:
#
#   UPDATE auth.users
#   SET app_metadata = jsonb_set(
#     COALESCE(app_metadata, '{}'::jsonb),
#     '{role}',
#     '"admin"'::jsonb,
#     true
#   )
#   WHERE email = 'admin@example.com';
#
# The user must then sign out and sign back in for the new claim to take effect.
