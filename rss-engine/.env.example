SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: worker run interval in milliseconds (default: 600000 = 10 minutes)
# RSS_INGESTION_INTERVAL_MS=600000

# Optional: RSS fetch timeout in milliseconds (default: 10000)
# RSS_FETCH_TIMEOUT_MS=10000

# Optional: retry settings for transient feed errors (default attempts=3, base delay=500)
# RSS_FETCH_RETRY_ATTEMPTS=3
# RSS_FETCH_RETRY_BASE_DELAY_MS=500
# RSS_FETCH_RETRY_MAX_DELAY_MS=8000

# Optional: number of articles to insert per batch (default: 50)
# INSERT_BATCH_SIZE=50

# ---------------------------------------------------------------------------
# Worker v2 (lease-based, heartbeat-driven; gated by `queue_based_ingestion`
# feature flag). Run with: pnpm rss:worker:v2
# ---------------------------------------------------------------------------
# Stable identity for this worker process. Defaults to rss-<host>-<pid>-<rand>.
# RSS_WORKER_ID=
# How often to send worker_heartbeat() (ms). Default 30000.
# RSS_HEARTBEAT_INTERVAL_MS=30000
# Sleep between successive lease batches when work is found (ms). Default 5000.
# RSS_CLAIM_INTERVAL_MS=5000
# Sleep when no feeds are due (ms). Default 30000.
# RSS_IDLE_POLL_INTERVAL_MS=30000
# Max feeds claimed per lease batch. Default 5.
# RSS_LEASE_BATCH_SIZE=5
# Lease window passed to lease_due_feeds() (seconds). Default 300.
# RSS_LEASE_SECONDS=300
# Max concurrent feed ingestions inside a worker. Default 3.
# RSS_FEED_CONCURRENCY=3
# How often to call mark_stale_workers_crashed() (ms). Default 60000.
# RSS_STALE_REAP_INTERVAL_MS=60000
# Heartbeat staleness threshold (seconds). Default 180.
# RSS_STALE_AFTER_SECONDS=180
# Max time to wait for in-flight feeds on SIGINT/SIGTERM (ms). Default 30000.
# RSS_SHUTDOWN_GRACE_MS=30000
# How often the running worker re-checks the activation flag (ms). Default 30000.
# RSS_FLAG_POLL_INTERVAL_MS=30000
