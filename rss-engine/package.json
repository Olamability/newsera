{
  "name": "newsera-rss-engine",
  "version": "1.0.0",
  "description": "RSS ingestion engine for Newsera",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "worker": "node worker.js",
    "worker:v2": "tsx workers/rss-worker.ts",
    "queue:runner": "tsx workers/queue-runner.ts",
    "notification:runner": "tsx workers/notification/dispatch/notification-runner.ts",
    "test:queue": "tsx workers/tests/queueRunner.simulation.ts",
    "test:notification": "tsx workers/tests/notification.simulation.ts",
    "test:personalization": "tsx workers/tests/personalization.simulation.ts",
    "test:phaseE": "tsx workers/tests/phaseE.simulation.ts",
    "test:phaseF": "tsx workers/tests/phaseF.simulation.ts",
    "test:phaseG": "tsx workers/tests/phaseG.simulation.ts",
    "test:all": "node scripts/run-all-tests.js",
    "validate:scripts": "tsx workers/tools/validateScripts.ts",
    "lint": "node --check index.js && node --check worker.js && node --check src/fetchRSS.js && node --check src/fetchSources.js && node --check src/deduplicateArticles.js && node --check src/saveArticles.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^17.4.2",
    "p-limit": "^3.1.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
